{
  "expo": {
    "name": "BandFan Mobile",
    "slug": "bandfan-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BandFan/BF Light No shadow.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "bandfan-mobile",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9EF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "space.bandfan.mobile",
      "permissions": [
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/BandFan/BF Light No shadow.png",
        "backgroundColor": "#FFF9EF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/BandFan/BF Light No shadow.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
